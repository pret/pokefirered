# -------------------------------------------------------
# Build output directory (object files, dependency files)
# -------------------------------------------------------
build/
*.o
*.d

# -------------------------------------------------------
# Final ROM / linker outputs
# -------------------------------------------------------
poke*.gba
poke*.elf
poke*.map

# -------------------------------------------------------
# Generated graphics files (produced by gbagfx from *.png)
# -------------------------------------------------------
*.1bpp
*.4bpp
*.8bpp
*.gbapal
*.lz
*.rl

# Binary artifacts removed by clean-assets
sound/**/*.bin

# Dependency and intermediate files emitted by the build system
*.i
*.ii
*.s~

# -------------------------------------------------------
# Generated font files
# -------------------------------------------------------
*.fwjpnfont
*.hwjpnfont
*.latfont

# -------------------------------------------------------
# Generated MIDI-to-assembly files (produced by mid2agb)
# -------------------------------------------------------
sound/songs/midi/*.s

# -------------------------------------------------------
# Generated JSON header / text files (produced by jsonproc)
# -------------------------------------------------------
src/data/*.h
src/data/*.json.txt
src/data/region_map/*.h
src/data/region_map/*.json.txt
include/constants/map_groups.h
include/constants/layouts.h

# Generated map/layout include files
data/layouts/layouts.inc
data/layouts/layouts_table.inc
data/maps/connections.inc
data/maps/events.inc
data/maps/groups.inc
data/maps/headers.inc
data/maps/**/connections.inc
data/maps/**/events.inc
data/maps/**/header.inc

# -------------------------------------------------------
# Editor / OS artifacts
# -------------------------------------------------------
.DS_Store
Thumbs.db
*~
*.swp
*.swo
