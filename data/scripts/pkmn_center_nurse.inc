EventScript_PkmnCenterNurse::
	goto_if_questlog EventScript_ReleaseEnd
	message Text_WelcomeWantToHealPkmn
	waitmessage
	multichoice 15, 8, MULTICHOICE_PKMN_CENTER_NURSE, FALSE | (TRUE << 1)
	switch VAR_RESULT
	case 0, EventScript_PkmnCenterNurse_HealPkmn
	case 1, EventScript_PkmnCenterNurse_LevelUpPokemon
	case 2, EventScript_PkmnCenterNurse_UpgradeStamina
	case 3, EventScript_PkmnCenterNurse_Goodbye
	case SCR_MENU_CANCEL, EventScript_PkmnCenterNurse_Goodbye
	end

EventScript_PkmnCenterNurse_LevelUpPokemon::
	showmoneybox 0, 0
EventScript_PkmnCenterNurse_LevelUpPokemon_Loop::
	special ChoosePartyMon
	waitstate
	goto_if_ge VAR_0x8004, PARTY_SIZE, EventScript_PkmnCenterNurse_LevelUpPokemon_End
	specialvar VAR_RESULT, PkmnCenterLevelUp_PrepareSelection
	goto_if_eq VAR_RESULT, 1, EventScript_PkmnCenterNurse_LevelUpPokemon_CantLevel
	goto_if_eq VAR_RESULT, 2, EventScript_PkmnCenterNurse_LevelUpPokemon_NotEnoughSouls
	goto_if_eq VAR_RESULT, 3, EventScript_PkmnCenterNurse_LevelUpPokemon_AtLevelCap
	goto_if_eq VAR_RESULT, 4, EventScript_PkmnCenterNurse_LevelUpPokemon_BreaksPartySpread
	msgbox Text_PkmnCenterNurse_LevelUpPrompt
EventScript_PkmnCenterNurse_LevelUpPokemon_AdjustAmount::
	specialvar VAR_RESULT, PkmnCenterLevelUp_UpdateSelection
	goto_if_eq VAR_RESULT, 1, EventScript_PkmnCenterNurse_LevelUpPokemon_CantLevel
	goto_if_eq VAR_RESULT, 2, EventScript_PkmnCenterNurse_LevelUpPokemon_NotEnoughSouls
	goto_if_eq VAR_RESULT, 3, EventScript_PkmnCenterNurse_LevelUpPokemon_AtLevelCap
	goto_if_eq VAR_RESULT, 4, EventScript_PkmnCenterNurse_LevelUpPokemon_BreaksPartySpread
	msgbox Text_PkmnCenterNurse_LevelUpAmountPrompt
	multichoice 20, 8, MULTICHOICE_PKMN_CENTER_LEVELUP_AMOUNT, FALSE
	goto_if_eq VAR_RESULT, 0, EventScript_PkmnCenterNurse_LevelUpPokemon_IncreaseAmount
	goto_if_eq VAR_RESULT, 1, EventScript_PkmnCenterNurse_LevelUpPokemon_DecreaseAmount
	goto_if_eq VAR_RESULT, 2, EventScript_PkmnCenterNurse_LevelUpPokemon_ConfirmAmount
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_Loop

EventScript_PkmnCenterNurse_LevelUpPokemon_IncreaseAmount::
	addvar VAR_0x8005, 1
	goto_if_gt VAR_0x8005, VAR_0x8006, EventScript_PkmnCenterNurse_LevelUpPokemon_SetMaxAmount
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_AdjustAmount

EventScript_PkmnCenterNurse_LevelUpPokemon_SetMaxAmount::
	copyvar VAR_0x8005, VAR_0x8006
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_AdjustAmount

EventScript_PkmnCenterNurse_LevelUpPokemon_DecreaseAmount::
	goto_if_eq VAR_0x8005, 1, EventScript_PkmnCenterNurse_LevelUpPokemon_AdjustAmount
	subvar VAR_0x8005, 1
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_AdjustAmount

EventScript_PkmnCenterNurse_LevelUpPokemon_ConfirmAmount::
	specialvar VAR_RESULT, PkmnCenterLevelUp_UpdateSelection
	goto_if_eq VAR_RESULT, 1, EventScript_PkmnCenterNurse_LevelUpPokemon_CantLevel
	goto_if_eq VAR_RESULT, 2, EventScript_PkmnCenterNurse_LevelUpPokemon_NotEnoughSouls
	goto_if_eq VAR_RESULT, 3, EventScript_PkmnCenterNurse_LevelUpPokemon_AtLevelCap
	goto_if_eq VAR_RESULT, 4, EventScript_PkmnCenterNurse_LevelUpPokemon_BreaksPartySpread
	msgbox Text_PkmnCenterNurse_LevelUpConfirmPrompt, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, NO, EventScript_PkmnCenterNurse_LevelUpPokemon_AdjustAmount
	goto_if_eq VAR_RESULT, SCR_MENU_CANCEL, EventScript_PkmnCenterNurse_LevelUpPokemon_AdjustAmount
	specialvar VAR_RESULT, PkmnCenterLevelUp_Purchase
	goto_if_eq VAR_RESULT, 1, EventScript_PkmnCenterNurse_LevelUpPokemon_CantLevel
	goto_if_eq VAR_RESULT, 2, EventScript_PkmnCenterNurse_LevelUpPokemon_NotEnoughSouls
	goto_if_eq VAR_RESULT, 3, EventScript_PkmnCenterNurse_LevelUpPokemon_AtLevelCap
	goto_if_eq VAR_RESULT, 4, EventScript_PkmnCenterNurse_LevelUpPokemon_BreaksPartySpread
	updatemoneybox
	msgbox Text_PkmnCenterNurse_LevelUpSuccess
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_Loop

EventScript_PkmnCenterNurse_LevelUpPokemon_NotEnoughSouls::
	msgbox Text_PkmnCenterNurse_NotEnoughSouls
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_Loop

EventScript_PkmnCenterNurse_LevelUpPokemon_CantLevel::
	msgbox Text_PkmnCenterNurse_CantLevel
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_Loop

EventScript_PkmnCenterNurse_LevelUpPokemon_AtLevelCap::
	msgbox Text_PkmnCenterNurse_LevelCapReached
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_Loop

EventScript_PkmnCenterNurse_LevelUpPokemon_BreaksPartySpread::
	msgbox Text_PkmnCenterNurse_PartySpreadViolation
	goto EventScript_PkmnCenterNurse_LevelUpPokemon_Loop

EventScript_PkmnCenterNurse_LevelUpPokemon_End::
	hidemoneybox
	goto EventScript_PkmnCenterNurse_Goodbye


EventScript_PkmnCenterNurse_UpgradeStamina::
	showmoneybox 0, 0
	specialvar VAR_RESULT, PkmnCenterStaminaUpgrade_Preview
	goto_if_eq VAR_RESULT, 1, EventScript_PkmnCenterNurse_UpgradeStamina_Max
	goto_if_eq VAR_RESULT, 2, EventScript_PkmnCenterNurse_UpgradeStamina_NotEnoughSouls
	msgbox Text_PkmnCenterNurse_StaminaUpgradePrompt, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, NO, EventScript_PkmnCenterNurse_UpgradeStamina_End
	goto_if_eq VAR_RESULT, SCR_MENU_CANCEL, EventScript_PkmnCenterNurse_UpgradeStamina_End
	specialvar VAR_RESULT, PkmnCenterStaminaUpgrade_Purchase
	goto_if_eq VAR_RESULT, 1, EventScript_PkmnCenterNurse_UpgradeStamina_Max
	goto_if_eq VAR_RESULT, 2, EventScript_PkmnCenterNurse_UpgradeStamina_NotEnoughSouls
	updatemoneybox
	msgbox Text_PkmnCenterNurse_StaminaUpgradeSuccess
	goto EventScript_PkmnCenterNurse_UpgradeStamina_End

EventScript_PkmnCenterNurse_UpgradeStamina_NotEnoughSouls::
	msgbox Text_PkmnCenterNurse_NotEnoughSouls
	goto EventScript_PkmnCenterNurse_UpgradeStamina_End

EventScript_PkmnCenterNurse_UpgradeStamina_Max::
	msgbox Text_PkmnCenterNurse_StaminaAlreadyMax

EventScript_PkmnCenterNurse_UpgradeStamina_End::
	hidemoneybox
	goto EventScript_PkmnCenterNurse_Goodbye

EventScript_PkmnCenterNurse_HealPkmn::
	setvar VAR_0x8004, 2
	specialvar VAR_RESULT, GetCorpseRunFieldBlockReason
	goto_if_eq VAR_RESULT, 0, EventScript_PkmnCenterNurse_HealPkmnContinue
	msgbox Text_CorpseRun_BlockHeal
	return

EventScript_PkmnCenterNurse_HealPkmnContinue::
	incrementgamestat GAME_STAT_USED_POKECENTER
	message Text_TakeYourPkmnForFewSeconds
	waitmessage
	call EventScript_PkmnCenterNurse_TakeAndHealPkmn
	special SetUsedPkmnCenterQuestLogEvent
	goto EventScript_PkmnCenterNurse_CheckTrainerTowerAndUnionRoom
	end

EventScript_PkmnCenterNurse_TakeAndHealPkmn::
	applymovement VAR_LAST_TALKED, Common_Movement_WalkInPlaceFasterLeft
	waitmovement 0
	dofieldeffect FLDEFF_POKECENTER_HEAL
	waitfieldeffect FLDEFF_POKECENTER_HEAL
	applymovement VAR_LAST_TALKED, Common_Movement_WalkInPlaceFasterDown
	waitmovement 0
	special HealPlayerParty
	return

EventScript_PkmnCenterNurse_CheckTrainerTowerAndUnionRoom::
	specialvar VAR_RESULT, IsPlayerNotInTrainerTowerLobby
	goto_if_eq VAR_RESULT, FALSE, EventScript_PkmnCenterNurse_ReturnPkmn
	specialvar VAR_RESULT, BufferUnionRoomPlayerName
	copyvar VAR_0x8008, VAR_RESULT
	goto_if_eq VAR_0x8008, 0, EventScript_PkmnCenterNurse_ReturnPkmn
	goto_if_eq VAR_0x8008, 1, EventScript_PkmnCenterNurse_PlayerWaitingInUnionRoom
	end

EventScript_PkmnCenterNurse_ReturnPkmn::
	message Text_RestoredPkmnToFullHealth
	waitmessage
	applymovement VAR_LAST_TALKED, Movement_Bow
	waitmovement 0
	msgbox Text_WeHopeToSeeYouAgain
	return

EventScript_PkmnCenterNurse_PlayerWaitingInUnionRoom::
	goto_if_set FLAG_SYS_INFORMED_OF_LOCAL_WIRELESS_PLAYER, EventScript_PkmnCenterNurse_ReturnPkmn
	msgbox Text_RestoredPkmnToFullHealth
	setflag FLAG_SYS_INFORMED_OF_LOCAL_WIRELESS_PLAYER
	message Text_PlayerIsPlayingRightNowGoForIt
	waitmessage
	applymovement VAR_LAST_TALKED, Movement_Bow
	waitmovement 0
	msgbox Text_WeHopeToSeeYouAgain
	return

EventScript_PkmnCenterNurse_Goodbye::
	msgbox Text_WeHopeToSeeYouAgain
	return

Movement_Bow::
	nurse_joy_bow
	delay_4
	step_end
